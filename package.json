{
  "name": "greytrace-backend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "tsc -b packages/contracts apps/api",
    "typecheck": "tsc -b convex packages/contracts apps/api --pretty false",
    "lint": "eslint .",
    "test": "pnpm build && vitest run",
    "test:watch": "vitest",
    "dev:api": "pnpm --filter @greytrace/api dev",
    "dev:convex": "convex dev"
  },
  "dependencies": {
    "@convex-dev/better-auth": "^0.11.3",
    "better-auth": "^1.5.5",
    "convex-helpers": "^0.1.114",
    "hono": "^4.12.8",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^24.0.15",
    "convex": "^1.34.0",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.2.4"
  }
}
